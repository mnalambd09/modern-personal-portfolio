{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A contact form message sent by a visitor.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The full name of the sender."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the sender."
        },
        "message": {
          "type": "string",
          "description": "The message content."
        },
        "read": {
          "type": "boolean",
          "description": "Whether the message has been read by the admin."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the message was sent."
        }
      },
      "required": ["name", "email", "message", "read", "createdAt"]
    },
    "Subscriber": {
      "title": "Subscriber",
      "description": "A newsletter subscriber.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the subscriber."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when they subscribed."
        }
      },
      "required": ["email", "createdAt"]
    },
    "Analytics": {
      "title": "Analytics",
      "description": "Website visitor analytics.",
      "type": "object",
      "properties": {
        "page": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" }
      },
      "required": ["page", "timestamp"]
    },
    "Newsletter": {
      "title": "Newsletter",
      "description": "A sent newsletter record.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "recipientCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "sentBy": { "type": "string" }
      },
      "required": ["subject", "message", "recipientCount", "createdAt", "sentBy"]
    }
  },
  "firestore": {
    "messages": {
      "schema": "Message",
      "description": "Collection of contact form messages."
    },
    "subscribers": {
      "schema": "Subscriber",
      "description": "Collection of newsletter subscribers."
    },
    "analytics": {
      "schema": "Analytics",
      "description": "Collection of page view analytics."
    },
    "newsletters": {
      "schema": "Newsletter",
      "description": "Collection of sent newsletters."
    }
  }
}
